{
  "name": "@pi/vscode-plugin",
  "displayName": "Pi Coding Agent VS Code Extension",
  "description": "VS Code extension for the pi coding agent.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Pi Coding Agent",
      "properties": {
        "pi.executablePath": {
          "type": "string",
          "default": "pi",
          "description": "Path to the Pi CLI executable. Defaults to 'pi'."
        }
      }
    },
    "commands": [
      {
        "command": "pi.start",
        "title": "Pi: Start Session",
        "category": "Pi"
      },
      {
        "command": "pi.startWithFile",
        "title": "Pi: Add Current File to Session",
        "category": "Pi"
      }
    ]
  },
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc",
    "watch": "tsc -watch",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.2.2"
  }
}
